{
  "id": "obsidian-dark",
  "name": "Obsidian",
  "author": "Kauan Vidigal",
  "version": "1.0.0",
  "mode": "dark",
  "supportsLightAndDarkModes": false,
  "colors": {
    "background": "#060A0A",
    "primary": "#14B8A6",
    "secondary": "#2DD4BF",
    "text": "#E0F2F1",
    "textSecondary": "#8FB5B2",
    "cardBackground": "#0E1817",
    "cardBorder": "#1E3331",
    "error": "#F87171",
    "success": "#2DD4BF"
  },
  "typography": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, Roboto, Helvetica, Arial, sans-serif",
    "fontSize": {
      "small": "0.875rem",
      "base": "1rem",
      "medium": "1.125rem",
      "large": "1.25rem",
      "xlarge": "2rem"
    }
  },
  "components": {
    "header": {
      "height": "80px",
      "backgroundColor": "#0B1220",
      "borderBottom": "1px solid #334155"
    },
    "footer": {
      "height": "60px",
      "backgroundColor": "#0B1220",
      "borderTop": "1px solid #334155"
    },
    "card": {
      "borderRadius": "16px",
      "padding": "24px",
      "boxShadow": "0 18px 60px rgba(0, 0, 0, 0.45)"
    },
    "button": {
      "borderRadius": "12px",
      "padding": "10px 18px",
      "border": "1px solid #334155",
      "hoverGlow": "0 0 0 3px rgba(124, 58, 237, 0.18)"
    },
    "select": {
      "borderRadius": "12px",
      "padding": "10px 40px 10px 16px",
      "border": "1px solid #334155",
      "backgroundColor": "#0F172A",
      "textAlign": "center",
      "iconColor": "#2DD4BF",
      "hoverBorderColor": "rgba(34, 211, 238, 0.7)",
      "focusBorderColor": "rgba(124, 58, 237, 0.8)",
      "focusGlow": "0 0 0 4px rgba(124, 58, 237, 0.18)"
    },
    "checkbox": {
      "width": "20px",
      "height": "20px",
      "accentColor": "#14B8A6",
      "borderColor": "#475569",
      "hoverBorderColor": "rgba(34, 211, 238, 0.75)",
      "checkMarkColor": "#060A0A",
      "borderRadius": "6px"
    }
  },
  "animations": {
    "enableTypingEffect": false,
    "enableGlow": true,
    "transitionDuration": "0.22s"
  }
}
