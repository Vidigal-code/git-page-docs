{
  "name": "gitpagedocs",
  "version": "1.1.7",
  "description": "CLI that generates out/ 100% like original site. npx gitpagedocs --serve to generate and view.",
  "main": "scripts/gitpagedocs-init.mjs",
  "bin": {
    "gitpagedocs": "scripts/gitpagedocs-init.mjs"
  },
  "files": [
    "scripts"
  ],
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"const fs=require('fs'); try{fs.rmSync('.next',{recursive:true})}catch(e){}\"",
    "build": "node scripts/gitpagedocs-init.mjs --build && node -e \"const fs=require('fs'); const o='out-init/gitpagedocs'; const g='gitpagedocs'; if(fs.existsSync(g)) fs.rmSync(g,{recursive:true}); fs.cpSync(o,g,{recursive:true}); try{fs.existsSync('out')&&fs.rmSync('out',{recursive:true})}catch(e){}\" && next build",
    "export": "next export",
    "prestart": "next build",
    "start": "next start",
    "lint": "eslint .",
    "gitpagedocs": "node scripts/gitpagedocs-init.mjs",
    "publish:create": "npm publish --access public --prefix packages/create-gitpagedocs",
    "publish:npm": "npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vidigal-code/git-page-docs.git"
  },
  "keywords": [
    "gitpagedocs",
    "documentation",
    "markdown",
    "spa",
    "cli",
    "github-pages",
    "create-gitpagedocs"
  ],
  "author": "Vidigal-code",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Vidigal-code/git-page-docs/issues"
  },
  "homepage": "https://vidigal-code.github.io/git-page-docs/",
  "dependencies": {},
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.20.1",
    "eslint-config-next": "^15.1.7",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.7",
    "next": "^15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "typescript": "^5.7.3"
  }
}
