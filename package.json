{
  "name": "gitpagedocs",
  "version": "1.1.0",
  "description": "Multi-language docs with themeable layouts for GitHub Pages repositories.",
  "main": "scripts/gitpagedocs-init.mjs",
  "bin": {
    "gitpagedocs": "./scripts/gitpagedocs-init.mjs",
    "gitpagedocs-init": "./scripts/gitpagedocs-init.mjs",
    "create-gitpagedocs": "./scripts/gitpagedocs-init.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"const fs=require('fs'); if(fs.existsSync('public/gitpagedocs')) fs.rmSync('public/gitpagedocs', {recursive:true}); fs.cpSync('gitpagedocs', 'public/gitpagedocs', {recursive:true, dereference:true})\" && next build",
    "prestart": "next build",
    "start": "next start",
    "lint": "eslint .",
    "gitpagedocs": "node scripts/gitpagedocs-init.mjs",
    "init:gitpagedocs": "node scripts/gitpagedocs-init.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vidigal-code/git-page-docs.git"
  },
  "keywords": [
    "gitpagedocs",
    "documentation",
    "markdown",
    "nextjs",
    "cli",
    "github-pages"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Vidigal-code/git-page-docs/issues"
  },
  "homepage": "https://vidigal-code.github.io/git-page-docs/",
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^15.0.7",
    "next": "^15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.20.1",
    "eslint-config-next": "^15.1.7",
    "typescript": "^5.7.3"
  }
}