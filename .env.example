# GitPageDocs environment variables
# Copy to .env and adjust as needed.

# Repository search: "true" = show search home, "false" = open docs directly
# Local dev typically uses false; official GitHub Pages aggregator uses true.
GITPAGEDOCS_REPOSITORY_SEARCH=false

# Base path for local dev only (when GITPAGEDOCS_REPOSITORY_SEARCH=false).
# Example: GITPAGEDOCS_PATH=gi-page-docs → localhost:3000/gi-page-docs
# Leave empty or omit for localhost:3000/
# GITPAGEDOCS_PATH=
